{
  "installCommand": "npm install --legacy-peer-deps --loglevel error",
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/temalar/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
