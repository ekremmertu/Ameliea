// Prisma Schema for Digital Invitations App
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  emailVerified DateTime?
  image         String?
  password      String? // For email/password auth (hashed)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  invitations   Invitation[]
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

// NextAuth Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth VerificationToken model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Invitation model (main entity)
model Invitation {
  id              String   @id @default(cuid())
  slug            String   @unique
  ownerId         String   // User who created this invitation
  
  // Couple information
  coupleName      String
  groomName       String
  brideName       String
  
  // Wedding details
  weddingDate     DateTime
  weddingTime     String?
  venueName       String
  venueAddress    String
  venueMapUrl     String?
  
  // Content
  personalMessage String?  @db.Text
  musicUrl        String?
  videoUrl        String?
  
  // Contact information
  contactPhone    String?
  contactEmail    String?
  contactWhatsApp String?
  
  // Features flags
  enableVideo     Boolean  @default(false)
  enableMusic     Boolean  @default(false)
  enableTestimonials Boolean @default(true)
  enableContact   Boolean  @default(false)
  enableSchedule  Boolean  @default(true)
  
  // Theme customization
  themePrimaryColor   String   @default("#c8a24a")
  themeSecondaryColor String   @default("#a12b3a")
  themeFontFamily     String   @default("serif")
  
  // RSVP settings
  rsvpDeadline    DateTime?
  
  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rsvps           RSVP[]
  guests          Guest[]
  scheduleItems   ScheduleItem[]
  testimonials    Testimonial[]

  @@index([slug])
  @@index([ownerId])
  @@map("invitations")
}

// Schedule items for wedding timeline
model ScheduleItem {
  id           String     @id @default(cuid())
  invitationId String
  time         String     // e.g., "16:00"
  event        String
  description  String?    @db.Text
  order        Int        @default(0) // For sorting
  
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  
  @@index([invitationId])
  @@map("schedule_items")
}

// Guest model (optional - for managing guest list)
model Guest {
  id           String     @id @default(cuid())
  invitationId String
  name         String
  email        String?
  phone        String?
  invited      Boolean    @default(true)
  invitedAt    DateTime?
  
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@index([invitationId])
  @@index([email])
  @@map("guests")
}

// RSVP responses
model RSVP {
  id                String     @id @default(cuid())
  invitationId      String
  
  // Guest information
  name              String
  email             String
  phone             String?
  
  // Response
  attending         Boolean
  guests            Int        @default(1) // Number of guests (including themselves)
  
  // Additional info
  dietaryRestrictions String?  @db.Text
  message           String?    @db.Text
  
  // Metadata
  submittedAt       DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  // Relations
  invitation        Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  
  @@index([invitationId])
  @@index([email])
  @@map("rsvps")
}

// Testimonials/guest messages
model Testimonial {
  id           String     @id @default(cuid())
  invitationId String
  name         String
  message      String     @db.Text
  approved     Boolean    @default(false) // Owner can approve before showing
  
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@index([invitationId])
  @@index([approved])
  @@map("testimonials")
}

