{
  "name": "web-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4174",
    "prebuild": "rm -rf .next/lock .next/*.tmp* 2>/dev/null; true",
    "build": "next build",
    "start": "next start -p 4174",
    "lint": "eslint",
    "ceo-check": "node scripts/ceo-preflight-check.js",
    "check-setup": "node scripts/check-setup.js",
    "check-setup:health": "node scripts/check-setup.js --health",
    "type-check": "tsc --noEmit",
    "corvus-sync": "node scripts/corvus-sync.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "test:load": "k6 run tests/load/homepage-stress.js",
    "test:load:api": "k6 run tests/load/api-stress.js",
    "test:load:full": "k6 run tests/load/full-stack-stress.js",
    "test:load:all": "npm run test:load && npm run test:load:api && npm run test:load:full",
    "test:invitation-api": "node scripts/test-invitation-api.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.49.0",
    "@vercel/speed-insights": "^1.3.1",
    "framer-motion": "^12.26.2",
    "iyzipay": "^2.0.64",
    "next": "16.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "node-mocks-http": "^1.14.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
