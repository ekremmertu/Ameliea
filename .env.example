# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (FULL ACCESS - Server-side only!)
# WARNING: Keep this secret! Never commit to git or expose to client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:4174
NODE_ENV=development

# Admin Configuration
# Comma-separated list of admin email addresses
# Server-side only (for backend admin checks)
ADMIN_EMAILS=admin@example.com

# Client-side admin emails (safe to expose, only for UI routing)
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Google Maps API Key (optional)
# Get from: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Iyzico Payment Gateway (optional - only required for payment features)
# Get from: https://merchant.iyzipay.com/
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Production values:
# IYZICO_BASE_URL=https://api.iyzipay.com
